# =============================================================================
# ExpertelIQ2 Scraper - Environment Variables Reference
# =============================================================================
# In production / QA / dev on AWS, this file is auto-generated by
# deployment/aws/terraform/modules/scraper-instance/templates/user_data.sh
# from values stored in AWS SSM Parameter Store.
#
# Use deployment/aws/manage-secrets.sh (or Manage-Secrets.ps1 on Windows) to
# set the SecureString secrets. Non-secret values are written by Terraform
# (see deployment/aws/terraform/environments/{env}/30-ssm.tf).
#
# Local development uses a 3-file scheme (all gitignored, switched by hand):
#   .env.production  - full production values (reference/backup, never loaded)
#   .env.local       - local-safe values: Mailtrap SMTP, local Postgres copy,
#                      alert emails pointing to the developer
#   .env             - the ONLY file Django loads; copy one of the above into it:
#                        cp .env.local .env        # safe default for development
#                        cp .env.production .env   # only when prod access is needed
# Refresh the local DB copy with scripts/sync_prod_db.sh (requires the SSM tunnel).
# =============================================================================

# Database (SSM: /experteliq2-scraper/{env}/database/*)
DB_HOST=xxxx.compute.amazonaws.com
DB_NAME=xxxx
DB_PASSWORD=xxx
DB_PORT=5432
DB_USERNAME=xxxx

# Backend API (SSM: /experteliq2-scraper/{env}/backend-api/*)
EIQ_BACKEND_API_BASE_URL=http://localhost:8000
EIQ_BACKEND_API_KEY=xxxxx

# Cryptography (SSM: /experteliq2-scraper/{env}/cryptography/key)
CRYPTOGRAPHY_KEY=xxxxx

# Azure (SSM: /experteliq2-scraper/{env}/azure/*)
CLIENT_ID=xxxa
TENANT_ID=xxxx
CLIENT_SECRET=xxxx
USER_EMAIL=notifications@expertel.com

# AI providers (SSM: /experteliq2-scraper/{env}/{anthropic,gemini}/api-key)
ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=xxxxx

# Captcha solvers (SSM: /experteliq2-scraper/{env}/{two-captcha,capsolver}/api-key)
TWO_CAPTCHA_API_KEY=xxxxx
CAPSOLVER_API_KEY=xxxxx

# MFA Service (SSM: /experteliq2-scraper/{env}/mfa-service/url)
MFA_SERVICE_URL=http://localhost:7000

# Email (SSM: /experteliq2-scraper/{env}/email/*)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-username
EMAIL_HOST_PASSWORD=your-password
EMAIL_USE_TLS=True
EMAIL_FROM_ADDRESS=iqnotifications@expertel.com
SCRAPER_ALERT_EMAILS=ops@expertel.com,alerts@expertel.com
SCRAPER_EXECUTION_LOG_EMAILS=alejandro@expertel.com
FRONTEND_URL=https://app.expertel.com

# Runtime context (set by Terraform / user_data.sh on EC2)
ENVIRONMENT=dev
SNS_TOPIC_ARN=
